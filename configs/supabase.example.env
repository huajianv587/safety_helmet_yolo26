SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
HELMET_STORAGE_BACKEND=supabase
HELMET_CONFIG_PATH=configs/runtime.json
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
ALERT_EMAIL_RECIPIENTS=
HELMET_PUBLISH_URL=rtmp://192.168.0.10:1935/live/stream
HELMET_MONITOR_STREAM_URL=rtmp://rtmp-gateway:1935/live/stream
camera_use_laptop_camera=false
HELMET_AUTH_USERS_FILE=artifacts/runtime/ops/auth_users.json
# If you keep bootstrap admin credentials in .env for Docker Compose, escape "$" as "$$".
# Example:
# HELMET_AUTH_ADMIN_USERNAME=admin
# HELMET_AUTH_ADMIN_PASSWORD_HASH=pbkdf2_sha256$$390000$$...$$...
