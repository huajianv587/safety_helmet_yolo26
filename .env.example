# Safety Helmet Monitoring System - Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# Supabase Configuration (Required for cloud storage and database)
# =============================================================================
# Get these values from your Supabase project dashboard at https://supabase.com
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_STORAGE_BUCKET=helmet-alerts

# =============================================================================
# Runtime Configuration
# =============================================================================
# Storage backend: 'supabase' (cloud) or 'local' (filesystem)
HELMET_STORAGE_BACKEND=supabase

# Path to runtime configuration file
HELMET_CONFIG_PATH=configs/runtime.json

# =============================================================================
# Email Notification Configuration (Optional)
# =============================================================================
# SMTP server configuration for sending alert emails
# Common enterprise SMTP hosts:
#   - Tencent Exmail: smtp.exmail.qq.com
#   - Alibaba Enterprise Mail: smtp.qiye.aliyun.com
#   - NetEase Enterprise Mail: smtp.qiye.163.com
#   - Microsoft 365: smtp.office365.com
#   - Google Workspace: smtp.gmail.com

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@example.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM_EMAIL=your-email@example.com
SMTP_USE_TLS=true

# Comma-separated list of email addresses to receive alerts
ALERT_EMAIL_RECIPIENTS=admin@example.com,safety@example.com

# =============================================================================
# LLM API Keys (Optional - for OCR disambiguation fallback)
# =============================================================================
# These are optional but recommended for improved badge OCR accuracy
# Get OpenAI key from: https://platform.openai.com/api-keys
# Get DeepSeek key from: https://platform.deepseek.com

OPENAI_API_KEY=sk-your-openai-api-key-here
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# =============================================================================
# Camera Stream Configuration
# =============================================================================
# Phone publish target for iPhone RTMP push apps
# This is where your phone camera will stream to
HELMET_PUBLISH_URL=rtmp://192.168.0.11:1935/live/stream

# Stream source consumed by the monitor
# For commercial IP cameras or NVR, use RTSP format:
# HELMET_MONITOR_STREAM_URL=rtsp://admin:password@192.168.1.88:554/Streaming/Channels/101
#
# For local development/testing, use RTMP or local camera:
HELMET_MONITOR_STREAM_URL=rtmp://rtmp-gateway:1935/live/stream

# Multi-camera mode (optional):
# Add numbered suffixes for multiple cameras
# HELMET_MONITOR_STREAM_URL_1=rtsp://admin:password@192.168.1.88:554/Streaming/Channels/101
# HELMET_MONITOR_STREAM_URL_2=rtsp://admin:password@192.168.1.89:554/Streaming/Channels/101
# HELMET_MONITOR_STREAM_URL_3=rtsp://admin:password@192.168.1.90:554/Streaming/Channels/101

# Optional metadata per camera (use same number suffix):
# HELMET_CAMERA_NAME_1=Main Entrance Camera
# HELMET_CAMERA_LOCATION_1=Building A - Entrance
# HELMET_CAMERA_NAME_2=Workshop Camera
# HELMET_CAMERA_LOCATION_2=Assembly Line B

# =============================================================================
# Console Authentication
# =============================================================================
# Default admin credentials for the web console
# IMPORTANT: Change these in production!
HELMET_AUTH_ADMIN_USERNAME=admin
HELMET_AUTH_ADMIN_PASSWORD=change-this-password

# =============================================================================
# Preview URLs (for reference)
# =============================================================================
# Streamlit UI: http://localhost:8501
# Browser preview: http://127.0.0.1:8876/browser/cam-local-001
# Frontend console: http://localhost:8000

# =============================================================================
# Performance Tuning (Optional - Advanced Configuration)
# =============================================================================
# These settings control system performance and resource usage
# Default values are optimized for typical deployments

# Frame processing stride (process every Nth frame)
# Higher values = lower CPU usage but may miss fast events
# Range: 1-10, Default: 3
HELMET_FRAME_STRIDE=3

# Preview frame rate (frames per second for live preview)
# Lower values = reduced bandwidth and CPU usage
# Range: 0.5-5, Default: 1
HELMET_PREVIEW_FPS=1

# JPEG compression quality for snapshots and previews
# Lower values = smaller files but reduced image quality
# Range: 50-95, Default: 75
HELMET_JPEG_QUALITY=75

# Cache maximum entries before eviction
# Higher values = more memory usage but better hit rate
# Range: 500-5000, Default: 1000
HELMET_CACHE_MAX_SIZE=1000

# Task queue worker threads (min/max for dynamic scaling)
# More workers = higher throughput but more CPU usage
# Min range: 1-4, Default: 2
# Max range: 4-16, Default: 8
HELMET_TASK_WORKER_MIN=2
HELMET_TASK_WORKER_MAX=8

# Database query result limit
# Lower values = faster queries but may need pagination
# Range: 100-10000, Default: 1000
HELMET_QUERY_LIMIT=1000

# WebSocket connection timeout (seconds)
# Higher values = more tolerant of slow networks
# Range: 30-300, Default: 60
HELMET_WS_TIMEOUT=60

# =============================================================================
# Security Notes
# =============================================================================
# 1. NEVER commit the actual .env file to version control
# 2. Rotate all credentials immediately if accidentally exposed
# 3. Use app-specific passwords for email (not your main password)
# 4. Keep SUPABASE_SERVICE_ROLE_KEY secret - it has full database access
# 5. Use strong passwords for HELMET_AUTH_ADMIN_PASSWORD in production
